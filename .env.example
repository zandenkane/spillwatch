# -------------------------------------------------------
# SpillWatch environment variables
# Copy this file to .env and fill in the values.
# -------------------------------------------------------

# PostgreSQL (with PostGIS)
DATABASE_URL=postgresql://spillwatch:spillwatch@localhost:5432/spillwatch
PGHOST=localhost
PGPORT=5432
PGDATABASE=spillwatch
PGUSER=spillwatch
PGPASSWORD=spillwatch
PG_MAX_CONNECTIONS=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=5000

# S3-compatible object storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=spillwatch
S3_REGION=us-east-1

# Clustering
CLUSTER_RADIUS_METERS=500
CLUSTER_TIME_WINDOW_HOURS=72
CLUSTER_MIN_REPORTS=2

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
